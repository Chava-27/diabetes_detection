# ==========================================
# Archivos temporales de Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Entornos virtuales
# ==========================================
venv/
.venv/
env/

# ==========================================
# Archivos de Jupyter Notebook
# ==========================================
.ipynb_checkpoints/

# ==========================================
# Configuración de editores
# ==========================================
.vscode/
.idea/

# ==========================================
# Archivos del sistema operativo
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Variables de entorno
# ==========================================
.env

# ==========================================
# Archivos de pruebas y cobertura
# ==========================================
.pytest_cache/
.coverage
htmlcov/

# ==========================================
# Datos del proyecto
# Mantener las carpetas, pero ignorar su contenido
# ==========================================
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

# ==========================================
# Modelos entrenados
# ==========================================
models/*
!models/.gitkeep

# ==========================================
# Reportes generados
# ==========================================
reports/*
!reports/.gitkeep

# ==========================================
# Credenciales de Kaggle
# ==========================================
kaggle.json